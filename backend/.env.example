# MongoDB connection string — local or Atlas
MONGO_URL=mongodb://localhost:27017
DB_NAME=stockai

# JWT secret — generate a random string (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Model to use (optional, defaults to claude-sonnet-4-5-20250929)
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# CORS origins — comma separated (the React dev server default)
CORS_ORIGINS=http://localhost:3000
